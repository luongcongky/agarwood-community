// ============================================================
// Agarwood Community Platform — Prisma Schema
// Database: PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  GUEST
  VIP
  ADMIN
}

enum AccountType {
  BUSINESS     // doanh nghiệp — có company, SP, chứng nhận
  INDIVIDUAL   // cá nhân/chuyên gia — chỉ feed, hồ sơ, tài liệu
}

// Phân hạng hội viên theo Điều lệ Hội (Chương II, Điều 7)
enum MemberCategory {
  OFFICIAL     // Hội viên chính thức — đầy đủ quyền biểu quyết, ứng cử, bầu cử
  AFFILIATE    // Hội viên liên kết — DN không đủ tiêu chuẩn chính thức, hoặc DN FDI
  HONORARY     // Hội viên danh dự — cá nhân/tổ chức uy tín, có đóng góp cho Hội
}

// Trạng thái đơn xin kết nạp Hội viên (Điều lệ Hội, Điều 11)
enum ApplicationStatus {
  PENDING      // đã nộp, chờ Ban Thường vụ xét duyệt
  APPROVED     // Chủ tịch đã ký quyết định công nhận
  REJECTED     // bị từ chối
}

// Phân loại bài viết trong News
enum NewsCategory {
  GENERAL      // Tin tức ngành — hiển thị ở /tin-tuc
  RESEARCH     // Nghiên cứu khoa học, báo cáo học thuật — hiển thị ở /nghien-cuu
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  PENDING_PAYMENT
}

enum PostStatus {
  PUBLISHED
  LOCKED   // bị lock do report vi phạm
  DELETED
}

enum PostCategory {
  GENERAL   // bài viết chung — mặc định, hiển thị ở /feed
  NEWS      // tin tức của doanh nghiệp — section "Tin doanh nghiệp" trang chủ
  PRODUCT   // tin sản phẩm (giới thiệu / vừa được chứng nhận) — section "Tin sản phẩm" trang chủ
}

enum ReportStatus {
  PENDING    // chờ admin xử lý
  REVIEWED   // đã xem xét, giữ bài
  DISMISSED  // bác report
  ACTIONED   // đã lock bài
}

enum CertStatus {
  DRAFT          // hội viên đang điền form
  PENDING        // đã nộp, chờ xét duyệt
  UNDER_REVIEW   // admin đang xét duyệt
  APPROVED       // được cấp badge
  REJECTED       // từ chối
  REFUNDED       // đã hoàn tiền
}

enum MediaOrderStatus {
  NEW            // vừa đặt hàng
  CONFIRMED      // admin đã xác nhận
  IN_PROGRESS    // đang thực hiện
  DELIVERED      // đã bàn giao bài viết
  REVISION       // khách yêu cầu chỉnh sửa
  COMPLETED      // hoàn tất, đã thanh toán
  CANCELLED
}

enum MediaServiceType {
  ARTICLE_COMPANY   // viết bài giới thiệu doanh nghiệp
  ARTICLE_PRODUCT   // viết bài giới thiệu sản phẩm
  PRESS_RELEASE     // thông cáo báo chí
  SOCIAL_CONTENT    // nội dung mạng xã hội
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  MEMBERSHIP_FEE      // phí hội viên hàng năm
  CERTIFICATION_FEE   // phí xét duyệt chứng nhận SP
  MEDIA_SERVICE       // phí dịch vụ truyền thông
  BANNER_FEE          // [Phase 6] phí đăng ký / gia hạn banner quảng cáo
}

enum BannerStatus {
  PENDING_PAYMENT     // user vừa tạo, chờ chuyển khoản
  PENDING_APPROVAL    // user đã CK, chờ admin duyệt content
  ACTIVE              // admin đã duyệt, đang chạy
  REJECTED            // admin từ chối content
  EXPIRED             // hết hạn (cron daily check)
}

enum BannerPosition {
  TOP   // Đầu trang chủ — ngay sau thanh menu
  MID   // Giữa trang chủ — sau section Sản phẩm chứng nhận
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String
  phone             String?
  avatarUrl         String?
  passwordHash      String?   // null cho OAuth users
  role              Role           @default(GUEST)
  accountType       AccountType    @default(BUSINESS)
  memberCategory    MemberCategory @default(OFFICIAL) // Điều lệ Hội, Chương II

  // Membership & ranking
  contributionTotal Int       @default(0) // tổng phí membership tích lũy (VND)
  displayPriority   Int       @default(0) // thứ tự ưu tiên hiển thị bài — tính từ contributionTotal
  reputationScore   Int       @default(100) // điểm uy tín — future use, schema sẵn sàng

  // Refund info — dùng khi hoàn phí chứng nhận bị từ chối
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?

  membershipExpires DateTime?
  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  memberships       Membership[]
  leaderPositions   Leader[]
  company           Company?
  products          Product[]       @relation("ProductOwner")
  posts             Post[]
  reports           Report[]        @relation("ReporterRelation")
  certifications    Certification[]
  mediaOrders       MediaOrder[]
  payments          Payment[]
  postReactions     PostReaction[]
  comments          Comment[]
  commentLikes      CommentLike[]
  banners           Banner[]
  applications      MembershipApplication[] @relation("ApplicantRelation")
  applicationsReviewed MembershipApplication[] @relation("ReviewerRelation")
  surveyResponses   SurveyResponse[]
  consultationRequests ConsultationRequest[] @relation("ConsultationRequester")
  consultationsHandled ConsultationRequest[] @relation("ConsultationHandler")

  @@index([role])
  @@index([accountType])
  @@index([contributionTotal])
  @@index([displayPriority])
  @@map("users")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// MEMBERSHIP & PAYMENT
// ============================================================

model Membership {
  id            String           @id @default(cuid())
  userId        String
  amountPaid    Int              // VND
  validFrom     DateTime
  validTo       DateTime
  status        MembershipStatus @default(ACTIVE)
  paymentRef    String?          // mã giao dịch PayOS
  note          String?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment       Payment?

  @@index([userId])
  @@index([status])
  @@index([validTo])
  @@map("memberships")
}

model Payment {
  id               String        @id @default(cuid())
  userId           String
  type             PaymentType
  status           PaymentStatus @default(PENDING)
  amount           Int           // VND
  payosOrderCode   String?       @unique  // mã đơn hàng PayOS
  payosTransId     String?       // mã giao dịch PayOS sau khi thành công
  description      String?
  failureReason    String?

  // Polymorphic reference — chỉ 1 trong 4 field này có giá trị
  membershipId     String?       @unique
  certificationId  String?       @unique
  mediaOrderId     String?       @unique
  bannerId         String?       // KHÔNG unique — 1 banner có thể có nhiều payment (đăng ký + nhiều lần gia hạn)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id])
  membership       Membership?   @relation(fields: [membershipId], references: [id])
  certification    Certification? @relation(fields: [certificationId], references: [id])
  mediaOrder       MediaOrder?   @relation(fields: [mediaOrderId], references: [id])
  banner           Banner?       @relation(fields: [bannerId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([payosOrderCode])
  @@index([createdAt])
  @@index([bannerId])
  @@map("payments")
}

// ============================================================
// COMPANY & PRODUCTS
// ============================================================

model Company {
  id               String    @id @default(cuid())
  ownerId          String    @unique  // 1 VIP = 1 company
  name             String
  slug             String    @unique  // dùng cho URL: /companies/[slug]
  description      String?   @db.Text
  logoUrl          String?
  coverImageUrl    String?
  website          String?
  phone            String?
  address          String?
  foundedYear      Int?
  employeeCount    String?   // "1-10", "10-50", "50-200",...
  businessLicense  String?   // số ĐKKD

  // Người đại diện tổ chức — bắt buộc theo Điều lệ Hội, Điều 7 Khoản 2c
  representativeName     String?
  representativePosition String?

  isVerified       Boolean   @default(false) // admin verify
  isPublished      Boolean   @default(true)

  // Featured (admin pin) — dùng cho landing page "Top doanh nghiệp tiêu biểu"
  isFeatured       Boolean   @default(false)
  featuredOrder    Int?      // null = chưa pin, số nhỏ = ưu tiên cao

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner            User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products         Product[]

  @@index([slug])
  @@index([isPublished])
  @@index([isFeatured, featuredOrder])
  @@map("companies")
}

model Product {
  id              String      @id @default(cuid())
  ownerId         String      // userId — ai đăng sản phẩm
  companyId       String?     // optional — chỉ có nếu owner có company (VIP)
  name            String
  slug            String      @unique
  description     String?     @db.Text
  imageUrls       String[]    // mảng URL ảnh sản phẩm (Cloudinary)
  category        String?     // loại trầm: trầm tự nhiên, trầm nuôi cấy, tinh dầu,...
  priceRange      String?     // "500k-1tr", "1tr-5tr",...
  isPublished     Boolean     @default(true)

  // Certification
  certStatus      CertStatus  @default(DRAFT)
  badgeUrl        String?     // URL badge chứng nhận (Cloudinary)
  certAppliedAt   DateTime?
  certApprovedAt  DateTime?
  certExpiredAt   DateTime?   // badge có thể có hạn sử dụng — future use

  // Featured (admin pin) — dùng cho menu "Sản phẩm tiêu biểu" + landing page "Top SP hot trend"
  isFeatured      Boolean     @default(false)
  featuredOrder   Int?        // null = chưa pin, số nhỏ = ưu tiên cao

  // Ranking — denormalized từ owner.displayPriority tại thời điểm đăng
  ownerPriority   Int         @default(0)

  // Liên kết với bài post trên feed (MXH Trầm Hương). 1-1 optional.
  // Khi Post bị xoá → cascade xoá Product (merge model: product luôn đi kèm 1 post).
  // Với product tạo trước khi gộp, cột này null cho đến khi backfill.
  postId          String?     @unique

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  owner           User        @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  post            Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  certifications  Certification[]
  comments        Comment[]

  @@index([ownerId])
  @@index([companyId])
  @@index([certStatus])
  @@index([slug])
  @@index([isFeatured, featuredOrder])
  @@index([ownerPriority])
  @@map("products")
}

// ============================================================
// CERTIFICATION
// ============================================================

model Certification {
  id                String      @id @default(cuid())
  productId         String
  applicantId       String      // userId của hội viên nộp đơn
  status            CertStatus  @default(PENDING)

  // Thông tin hồ sơ
  documentUrls      String[]    // tài liệu đính kèm (Cloudinary)
  applicantNote     String?     @db.Text
  reviewNote        String?     @db.Text // ghi chú của admin khi duyệt/từ chối

  // Thanh toán & hoàn tiền
  feePaid           Int         @default(500000000) // 5.000.000 VND (lưu bằng đồng, *100)
  refundBankName    String?
  refundAccountName String?
  refundAccountNo   String?
  refundedAt        DateTime?
  refundNote        String?

  // Xét duyệt
  reviewedBy        String?     // adminId
  reviewedAt        DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?

  // Process type
  isOnlineReview    Boolean     @default(true) // true = online, false = offline

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  product           Product     @relation(fields: [productId], references: [id])
  applicant         User        @relation(fields: [applicantId], references: [id])
  payment           Payment?

  @@index([productId])
  @@index([applicantId])
  @@index([status])
  @@map("certifications")
}

// ============================================================
// SOCIAL FEED — POSTS & INTERACTIONS
// ============================================================

model Post {
  id              String      @id @default(cuid())
  authorId        String
  title           String?
  content         String      @db.Text
  imageUrls       String[]    // ảnh đính kèm (Cloudinary)
  status          PostStatus  @default(PUBLISHED)

  // Loại bài — phân biệt tin tức DN / tin sản phẩm / bài thường
  category        PostCategory @default(GENERAL)

  // Visibility
  isPremium       Boolean     @default(false) // true nếu author là VIP — set tự động
  isPromoted      Boolean     @default(false) // admin có thể pin bài lên top

  // Ranking — denormalized từ author.displayPriority tại thời điểm đăng
  // Cập nhật lại khi hội viên gia hạn membership
  authorPriority  Int         @default(0)

  // Engagement
  viewCount       Int         @default(0)
  reportCount     Int         @default(0)

  // Lock info
  lockedAt        DateTime?
  lockedBy        String?     // adminId
  lockReason      String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  author          User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  product         Product?    // sidecar metadata khi category=PRODUCT
  reports         Report[]
  reactions       PostReaction[]
  tags            PostTag[]
  comments        Comment[]

  @@index([authorId])
  @@index([status])
  @@index([isPremium])
  @@index([authorPriority, createdAt])
  @@index([status, createdAt])
  @@index([isPromoted, authorPriority, createdAt]) // feed ORDER BY
  @@index([createdAt])
  @@index([category, createdAt])                    // homepage queries: latest by category
  @@index([category, isPremium, authorPriority])    // homepage VIP-priority queries
  @@map("posts")
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   @default("LIKE") // LIKE, LOVE,... mở rộng sau

  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId]) // 1 user chỉ react 1 lần / bài
  @@map("post_reactions")
}

// ============================================================
// COMMENTS — polymorphic (Post + Product)
// ============================================================

model Comment {
  id          String    @id @default(cuid())
  authorId    String
  content     String    @db.Text

  // Polymorphic target — exactly one of postId/productId must be set
  postId      String?
  productId   String?

  // Reply — flat with mention (parentId = comment being replied to)
  parentId    String?

  // Soft delete
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post        Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies     Comment[] @relation("CommentReplies")
  likes       CommentLike[]

  @@index([postId, createdAt])
  @@index([productId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String

  createdAt DateTime @default(now())

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId]) // 1 user chỉ like 1 lần / comment
  @@map("comment_likes")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique

  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ============================================================
// REPORT & MODERATION
// ============================================================

model Report {
  id           String       @id @default(cuid())
  postId       String
  reporterId   String
  reason       String       // "SPAM", "FAKE_INFO", "INAPPROPRIATE", "OTHER"
  description  String?      @db.Text
  status       ReportStatus @default(PENDING)

  reviewedBy   String?      // adminId
  reviewedAt   DateTime?
  adminNote    String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter     User         @relation("ReporterRelation", fields: [reporterId], references: [id])

  @@unique([postId, reporterId]) // 1 user chỉ report 1 lần / bài
  @@index([postId])
  @@index([status])
  @@map("reports")
}

// ============================================================
// NEWS & ANNOUNCEMENTS (Ban quản trị hội đăng)
// ============================================================

model News {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  excerpt      String?
  content      String       @db.Text
  coverImageUrl String?
  category     NewsCategory @default(GENERAL)
  isPublished  Boolean      @default(false)
  isPinned     Boolean      @default(false)
  publishedAt  DateTime?
  authorId     String       // adminId

  // Import metadata — dùng khi crawl từ website cũ
  sourceUrl      String?    // URL gốc trên trang cũ (step 2 crawl sẽ dùng)
  originalAuthor String?    // Tên tác giả gốc (vd "Admin", "BBT") — hiển thị khi có, không thay authorId

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([category, isPublished, publishedAt])
  @@index([slug])
  @@map("news")
}

// ============================================================
// MEDIA SERVICE — DỊCH VỤ TRUYỀN THÔNG
// ============================================================

model MediaOrder {
  id              String           @id @default(cuid())
  requesterId     String?          // userId đặt dịch vụ (null nếu là guest)
  requesterName   String           // lưu lại tên lúc đặt
  requesterEmail  String
  requesterPhone  String

  serviceType     MediaServiceType
  status          MediaOrderStatus @default(NEW)

  // Yêu cầu từ khách
  requirements    String           @db.Text
  targetKeywords  String?          // từ khóa SEO mong muốn
  referenceUrls   String[]         // URL tham khảo
  deadline        DateTime?        // deadline mong muốn của khách
  budget          String?          // ngân sách dự kiến

  // Xử lý nội bộ
  assignedTo      String?          // email/tên nhân sự phụ trách
  quotedPrice     Int?             // giá báo (VND)
  internalNote    String?          @db.Text
  deliveryFileUrls String[]        // URL file bài viết bàn giao (Cloudinary)
  deliveredAt     DateTime?
  completedAt     DateTime?
  cancelReason    String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  requester       User?            @relation(fields: [requesterId], references: [id])
  payment         Payment?

  @@index([requesterId])
  @@index([status])
  @@index([serviceType])
  @@map("media_orders")
}

// ============================================================
// SITE CONFIG — cấu hình chung của website
// ============================================================

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique  // "membership_fee_min", "membership_fee_max", "cert_fee",...
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}

// ============================================================
// BANNER ADS — Phase 6
// ============================================================

model Banner {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  imageUrl      String       // Cloudinary URL
  targetUrl     String       // link tới DN/SP/bài post (mở tab mới khi click)
  title         String       // tiêu đề ngắn (hiện tooltip + alt)
  position      BannerPosition @default(TOP) // vị trí hiển thị trên trang chủ

  // Schedule
  startDate     DateTime     // ngày bắt đầu hiển thị
  endDate       DateTime     // ngày hết hạn (extend khi gia hạn)

  // Workflow
  status        BannerStatus @default(PENDING_PAYMENT)
  rejectReason  String?      @db.Text  // ghi chú khi admin từ chối
  approvedAt    DateTime?
  approvedBy    String?      // adminId

  // Payment & pricing
  price         Int          // tổng tiền đăng ký lần đầu (VND) — không update khi gia hạn

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  payments      Payment[]    // 1 banner → nhiều payment (lần đầu + các lần gia hạn)

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([status, endDate])  // homepage query: ACTIVE + đang trong khoảng startDate-endDate
  @@index([status, position, endDate])  // homepage query tách theo position
  @@map("banners")
}

// ============================================================
// DOCUMENT MANAGEMENT — Công văn, tài liệu nội bộ
// ============================================================

enum DocumentCategory {
  CONG_VAN_DEN    // công văn đến
  CONG_VAN_DI     // công văn đi
  BIEN_BAN_HOP    // biên bản họp
  QUYET_DINH      // quyết định
  HOP_DONG        // hợp đồng
  // ── Văn bản pháp quy (Public, hiển thị trên /phap-ly) ──
  DIEU_LE         // Điều lệ Hội
  QUY_CHE         // Quy chế nội bộ (VAWA)
  GIAY_PHEP       // Giấy phép Đại hội
}

model Document {
  id                String            @id @default(cuid())
  title             String
  description       String?           @db.Text
  category          DocumentCategory
  documentNumber    String?           // số hiệu công văn (vd: CV-2026-001, 56/QĐ-VAWA)
  issuedDate        DateTime?         // ngày ban hành
  issuer            String?           // cơ quan / người ban hành (vd: "Chủ tịch VAWA", "Bộ Nội vụ")
  sortOrder         Int               @default(0) // thứ tự hiển thị trên /phap-ly
  isPublic          Boolean           @default(false) // true = hiển thị trên /phap-ly (public)

  // Google Drive
  driveFileId       String            @unique
  driveViewUrl      String
  driveDownloadUrl  String
  fileName          String
  mimeType          String
  fileSize          Int               // bytes

  // AI extracted content
  extractedText     String?           @db.Text
  summary           String?           @db.Text

  // Metadata
  uploadedBy        String            // adminId
  downloadCount     Int               @default(0)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([category])
  @@index([isPublic])
  @@index([createdAt])
  @@map("documents")
}

// ============================================================
// MEMBERSHIP APPLICATION — Đơn xin kết nạp Hội viên
// Theo Điều lệ Hội, Điều 11: BCH xét hồ sơ → Chủ tịch quyết định trong 30 ngày
// ============================================================

// ============================================================
// LEADER — Ban lãnh đạo theo nhiệm kỳ
// ============================================================

model Leader {
  id        String         @id @default(cuid())
  name      String
  title     String         // "Chủ tịch", "Phó Chủ tịch", "Tổng Thư ký", "Ủy viên", ...
  category  LeaderCategory @default(BCH) // nhóm chính hiển thị
  workTitle String?        // chức vụ đơn vị công tác
  bio       String?        @db.Text
  photoUrl  String?
  term      String         // "Nhiệm kỳ III (2023–2028)"
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)

  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([isActive, category, sortOrder])
  @@index([term])
  @@map("leaders")
}

enum LeaderCategory {
  BTV // Ban Thường vụ
  BCH // Ủy viên Ban Chấp hành
  BKT // Ban Kiểm tra
}

// ============================================================
// MEMBERSHIP APPLICATION — Đơn xin kết nạp Hội viên
// Theo Điều lệ Hội, Điều 11: BCH xét hồ sơ → Chủ tịch quyết định trong 30 ngày
// ============================================================

model MembershipApplication {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation("ApplicantRelation", fields: [userId], references: [id], onDelete: Cascade)

  // Nội dung đơn
  requestedCategory MemberCategory     @default(OFFICIAL) // hạng hội viên xin kết nạp
  reason            String             @db.Text // lý do xin gia nhập, giới thiệu bản thân / tổ chức
  representativeName     String?       // với tổ chức
  representativePosition String?       // với tổ chức

  // Xử lý
  status            ApplicationStatus  @default(PENDING)
  submittedAt       DateTime           @default(now())
  reviewedAt        DateTime?
  reviewedById      String?
  reviewer          User?              @relation("ReviewerRelation", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectReason      String?            @db.Text

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("membership_applications")
}

// ============================================================
// SURVEY SYSTEM — generic, dùng nhiều loại khảo sát
// ============================================================

enum SurveyAudience {
  ALL          // mọi user (kể cả guest đã login)
  BUSINESS     // chỉ accountType = BUSINESS
  INDIVIDUAL   // chỉ accountType = INDIVIDUAL
  BOTH_VIP     // cả BUSINESS + INDIVIDUAL (loại GUEST)
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ConsultationStatus {
  PENDING
  CONTACTED
  DONE
  CANCELLED
}

/**
 * Bộ khảo sát động — admin tạo qua UI. Câu hỏi lưu dạng JSON, có thể có
 * `mapsTo` để tự đồng bộ câu trả lời sang field User/Company tương ứng.
 *
 * Cấu trúc 1 câu hỏi (trong `questions` JSON):
 *   {
 *     id: string,                    // unique trong scope survey
 *     label: string,                 // câu hỏi hiển thị
 *     type: "text"|"textarea"|"number"|"select"|"multiselect"|"scale",
 *     options?: string[],            // cho select/multiselect
 *     required?: boolean,
 *     mapsTo?: "user.fieldName"|"company.fieldName",
 *     scoreRule?: Record<string, number>,  // map giá trị → điểm cho recommendation
 *     helpText?: string,
 *   }
 */
model Survey {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String?        @db.Text
  audience    SurveyAudience @default(BOTH_VIP)
  status      SurveyStatus   @default(DRAFT)
  questions   Json           // mảng câu hỏi (xem comment trên)
  config      Json?          // { scoring: {...}, recommendation: {...} } — tùy loại survey
  startsAt    DateTime?
  endsAt      DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  responses   SurveyResponse[]

  @@index([status, audience])
  @@map("surveys")
}

/**
 * Phản hồi khảo sát — cho phép cả user đã đăng nhập và khách public.
 *  - userId: set nếu người trả lời là member đã login (giữ mirror mapsTo)
 *  - contact*: thông tin user tự điền (bắt buộc với public submissions)
 *  - submitterType: "INDIVIDUAL" | "BUSINESS" — user tự chọn ở step đầu
 */
model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  userId      String?

  // Contact info (do user tự điền, bắt buộc cho anon)
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  avatarUrl      String?  // ảnh đại diện cá nhân (cho INDIVIDUAL)
  companyName    String?
  logoUrl        String?
  submitterType  String?  // "INDIVIDUAL" | "BUSINESS"

  answers         Json
  score           Int?
  recommendedTier String?
  submittedAt     DateTime @default(now())

  // IP để dedupe / rate-limit theo request (tùy chọn lưu)
  submitterIp String?

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([surveyId, submittedAt])
  @@index([userId])
  @@index([contactEmail])
  @@map("survey_responses")
}

/**
 * Yêu cầu tư vấn nâng cấp — phát sinh từ CTA cuối flow khảo sát.
 * Giai đoạn này chưa có flow thanh toán nâng cấp tự động → chỉ ghi nhận
 * để admin liên hệ lại.
 */
model ConsultationRequest {
  id          String             @id @default(cuid())
  userId      String?            // null nếu anon (từ /khao-sat public)
  fullName    String
  phone       String
  email       String?
  companyName String?
  note        String?            @db.Text
  context     String?            // "survey:member-onboarding" — nguồn phát sinh
  recommendedTier String?
  status      ConsultationStatus @default(PENDING)
  handledById String?
  handledAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User?              @relation("ConsultationRequester", fields: [userId], references: [id], onDelete: SetNull)
  handledBy   User?              @relation("ConsultationHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId])
  @@map("consultation_requests")
}
